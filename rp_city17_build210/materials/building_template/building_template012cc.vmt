"LightmappedGeneric"
{
	"$basetexture" "Building_Template/Building_Template012cc"
	"$surfaceprop" "concrete"
	"$envmap" "env_cubemap"
	"$basealphaenvmapmask" 1
	"$envmapcontrast" 1
	"$envmapsaturation" 1
	"$envmaptint" "[ .75 .75 .75]"
	"LightmappedGeneric_DX8"
	{
		"$envmaptint" "[.25 .25 .25]"
	} 
	"$texscale"	4
	"$baseTextureOffset" "[0.5 0.5]"
	"Proxies"
     	{
            "TextureTransform"
            {
		   "translateVar" "$baseTextureOffset"
		   "scaleVar"     "$texscale"
                   "resultVar"    "$baseTextureTransform"

            }
     	}
}
