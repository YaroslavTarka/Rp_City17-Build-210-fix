// envmaptint_fix
"LightmappedGeneric"
{
	"$basetexture" "concrete\concretefloor039bb"
	"$surfaceprop" "concrete"
	"%keywords" "c17downtown"
	"$texscale"	4
	"$baseTextureOffset" "[0.5 0.5]"
	"Proxies"
     	{
       "TextureTransform"
            {
		   			"translateVar" "$baseTextureOffset"
		   			"scaleVar"     "$texscale"
       			"resultVar"    "$baseTextureTransform"
            }

     	}

}
