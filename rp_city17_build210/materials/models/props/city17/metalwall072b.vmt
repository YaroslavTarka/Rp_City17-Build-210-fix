// envmaptint_fix
"vertexlitgeneric"
{
	"$basetexture" "metal/metalwall072b"
	"$surfaceprop"  "metal"
	"$detail" "detail\metal_detail_01"
	"$detailscale" "4.283"
	"$detailblendfactor" .8
	"$detailblendmode" "0"

	"%keywords" "combine"
	"$bumpmap" "metal/metalwall072b_normal"
	//"$nodiffusebumplighting" 1
	"$envmaptint" "[ .56 .56 .75 ]"
	"$envmap" "env_cubemap"
	"$normalmapalphaenvmapmask" 1
	"$envmapcontrast" 1
	"$envmapsaturation" 1
//	"$parallaxmap" "metal/metalwall072b_height"
//	"$parallaxmapscale" ".05"

	"vertexlitgeneric_hdr_dx9"
	{
		"$envmaptint" "[ .09 .1 .12]"	
	}

	"vertexlitgeneric_dx9"
	{
		"$envmaptint" "[ .09 .1 .12]"	
	}
}

